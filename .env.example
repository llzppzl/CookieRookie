# Debug Agent 配置文件
# 复制此文件为 .env 并填入你的配置

# API Key (required)
# 支持多种模型供应商，选择你喜欢的:
# - Minimax (国内稳定): https://api.minimax.io
# - DeepSeek (便宜): https://api.deepseek.com
# - Kimi (月之暗面): https://api.moonshot.ai
# - GLM (智谱): https://api.z.ai
# - Anthropic (Claude): https://api.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# Model ID (required)
# 推荐: MiniMax-M2.5, deepseek-chat, kimix-x, glm-5
MODEL_ID=MiniMax-M2.5

# Base URL (required)
# 根据你使用的模型供应商选择:
# Minimax:    https://api.minimax.io/anthropic
# DeepSeek:    https://api.deepseek.com/anthropic
# Kimi:        https://api.moonshot.ai/anthropic
# GLM:         https://api.z.ai/api/anthropic
# Anthropic:   https://api.anthropic.com
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
